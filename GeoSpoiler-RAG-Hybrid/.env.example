# ===== TELEGRAM =====
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
TELEGRAM_PHONE=+your-phone-number

# ===== LLM (OpenAI-compatible API) =====
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
LLM_MAX_ASYNC=1
LLM_DELAY_SECONDS=2.0
RAG_BUILD_DELAY_SECONDS=2.0
QUERY_DELAY_SECONDS=0.0
RAG_INSERT_TIMEOUT_SECONDS=600
RAG_DELETE_TIMEOUT_SECONDS=120
QUERY_TIMEOUT_SECONDS=240
FALLBACK_SYNTH_TIMEOUT_SECONDS=45
RAG_FINALIZE_TIMEOUT_SECONDS=30
QUERY_MAX_TOKENS=1200
FALLBACK_SYNTH_MAX_TOKENS=4096
# Optional for reasoning/thinking models on OpenAI-compatible endpoints.
LLM_REASONING_EFFORT=
HYBRID_QUERY_CARDS_ENABLED=true
HYBRID_SYNTH_ENABLED=true
HYBRID_QUERY_CARDS_TOP_K=3
WIKI_ENABLED=true
WIKI_TOP_K=5

# Optional role-specific chat models. Empty values fall back to LLM_*.
RAG_BUILD_API_KEY=
RAG_BUILD_BASE_URL=
RAG_BUILD_MODEL=
QUERY_API_KEY=
QUERY_BASE_URL=
QUERY_MODEL=
FALLBACK_SYNTH_API_KEY=
FALLBACK_SYNTH_BASE_URL=
FALLBACK_SYNTH_MODEL=
TRANSLATION_API_KEY=
TRANSLATION_BASE_URL=
TRANSLATION_MODEL=
TRANSCRIPTION_ENABLED=false
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_LANGUAGE=
TRANSCRIPTION_TIMEOUT_SECONDS=120
ENRICHMENT_API_KEY=
ENRICHMENT_BASE_URL=
ENRICHMENT_MODEL=
ENRICHMENT_SCHEMA_VERSION=1

# ===== EMBEDDING =====
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_TIMEOUT_SECONDS=120
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_ATTEMPTS=6
EMBEDDING_CONCURRENCY=1

# ===== VISION API =====
VISION_API_KEY=your-api-key-here
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o

# ===== RERANKER =====
RERANKER_ENABLED=false
RERANKER_PROVIDER=nim
RERANKER_MODEL=nvidia/llama-nemotron-rerank-1b-v2
RERANKER_API_KEY=
RERANKER_BASE_URL=https://integrate.api.nvidia.com/v1
RERANKER_TOP_N=10
RERANKER_CANDIDATE_POOL=50

# ===== PATHS =====
OUTPUT_DIR=./output
RAG_STORAGE_DIR=./rag_storage
CARD_FTS_DB_PATH=./artifacts/card_fts.sqlite
SOURCE_REGISTRY_DB_PATH=./artifacts/source_registry.sqlite
STATE_DIR=./state
MEDIA_CACHE_DIR=./media_cache
LOG_DIR=./logs
MEDIA_CAPTURE_ENABLED=true
# 0 means no size limit. Set a byte limit to skip very large native media downloads.
MEDIA_CAPTURE_MAX_BYTES=0
