  <data key="d0">Ukrainian Ministry of Foreign Affairs</data>
  <data key="d1">organization</data>
  <data key="d2">The Ukrainian Ministry of Foreign Affairs is an organization that launched the radio program "Венгерское радио Украины" to counter disinformation from Hungarian Prime Minister Orbán and his team.</data>
  <data key="d3">chunk-b27aeca6858b7e54f862c47192fbcea2</data>
