</node>
<node id="Sabolc Páni">
  <data key="d0">Sabolc Páni</data>
  <data key="d1">person</data>
  <data key="d2">Sabolc Páni is a Hungarian journalist who published a transcript of a conversation between Hungarian Foreign Minister Sándor Pintér and Sergey Lavrov regarding Slovak elections.</data>
  <data key="d3">chunk-a55a1b2f7d86f155201f7562a7195495</data>
