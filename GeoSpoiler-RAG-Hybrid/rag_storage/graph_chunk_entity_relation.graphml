<edge source="Mádiár" target="Judit Varga">
  <data key="d8">1.0</data>
  <data key="d9">Mádiár released private recordings of conversations with his ex-wife Judit Varga, in which she discussed efforts to cover up corruption within Orbán’s government.</data>
  <data key="d10">marriage,recording_leak</data>
  <data key="d11">chunk-49d9496e943d94ccc071cf105396b990</data>
