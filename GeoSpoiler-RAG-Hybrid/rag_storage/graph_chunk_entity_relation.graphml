  <data key="d14"></data>
</edge>
<edge source="Newgard" target="TikTok">
  <data key="d8">2.0</data>
  <data key="d9">Newgard reported 34 malicious TikTok accounts to TikTok, leading to their official suspension as part of a coordinated influence operation.&lt;SEP&gt;TikTok officially confirmed the blocking of the 34 accounts after receiving the list from Newgard, validating the scale of the operation.</data>
  <data key="d10">acknowledgment,action,cooperation,reporting</data>
  <data key="d11">chunk-95251bcfc4d08a0a36c341b9a9e2da54</data>
