  <data key="d6"></data>
</node>
<node id="Hungarian interrogators">
  <data key="d0">Hungarian interrogators</data>
  <data key="d1">organization</data>
  <data key="d2">Hungarian interrogators are individuals who visited the speaker in prison multiple times, conducted a polygraph test, and questioned him, claiming to be sent by Sándor Pintér.</data>
  <data key="d3">chunk-53047d8273819f991ab1b18d7532d438</data>
