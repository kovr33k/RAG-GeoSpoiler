<edge source="Ukraine" target="North Korean Soldiers">
  <data key="d8">1.0</data>
  <data key="d9">Ukraine is the location where North Korean Soldiers are held as prisoners of war and from which they requested transfer to South Korea.</data>
  <data key="d10">detention location</data>
