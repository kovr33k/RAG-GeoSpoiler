</edge>
<edge source="Будоверш" target="Сантендра">
  <data key="d8">1.0</data>
  <data key="d9">Budoverš is located on the opposite side of Budapest from Szentendre, serving as a geographical reference point.</data>
  <data key="d10">geographical_relation</data>
  <data key="d11">chunk-9eb97f8c573cf721a0206d7b0dff7868</data>
