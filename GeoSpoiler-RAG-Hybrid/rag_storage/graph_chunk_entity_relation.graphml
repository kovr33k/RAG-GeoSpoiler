</node>
<node id="Peter Márki-Zay">
  <data key="d0">Peter Márki-Zay</data>
  <data key="d1">person</data>
  <data key="d2">Peter Márki-Zay is a Hungarian anti-corruption reformer and political opponent of Viktor Orbán, portrayed by Russian operatives as a "puppet of Brussels" in influence operations.</data>
  <data key="d3">chunk-583ccb318ed3bd5eb71b569940315d4f</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\95.txt</data>
