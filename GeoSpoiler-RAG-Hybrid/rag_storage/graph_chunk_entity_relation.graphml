<node id="Planet Labs">
  <data key="d0">Planet Labs</data>
  <data key="d1">organization</data>
  <data key="d2">Planet Labs provided satellite imagery on February 21 showing the empty storage tank at the Brody Pumping Station 25 days after the attack.</data>
  <data key="d3">chunk-141360bcc1e8268affe7476ca1b210ea</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\33.txt</data>
  <data key="d5">1777933482</data>
