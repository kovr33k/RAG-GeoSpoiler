</node>
<node id="Пинтер Шандер">
  <data key="d0">Пинтер Шандер</data>
  <data key="d1">person</data>
  <data key="d2">Пинтер Шандер is described as the biggest criminal in Hungary according to investigators, and is associated with the creation of the NVS brigade.</data>
  <data key="d3">chunk-85ab176e3cbddf97c2d5cd15191ff861</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
