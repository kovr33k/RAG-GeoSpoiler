</node>
<node id="Szombathely">
  <data key="d0">Szombathely</data>
  <data key="d1">location</data>
  <data key="d2">Szombathely is a city in Hungary where the speaker was initially imprisoned, located 250 km from Budapest.&lt;SEP&gt;Szombathely is a location in Hungary where the speaker was transferred after being sentenced.</data>
  <data key="d3">chunk-53047d8273819f991ab1b18d7532d438&lt;SEP&gt;chunk-85ab176e3cbddf97c2d5cd15191ff861</data>
