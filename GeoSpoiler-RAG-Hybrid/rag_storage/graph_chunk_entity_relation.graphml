<node id="Oshchadbank">
  <data key="d0">Oshchadbank</data>
  <data key="d1">organization</data>
  <data key="d2">Oshchadbank is a Ukrainian bank whose cash-in-transit officers were deported from Hungary.&lt;SEP&gt;Oshchadbank is a financial institution from which funds were seized and are subject to temporary confiscation under the proposed legislation.</data>
  <data key="d3">chunk-350a5144d8e2787035e85988d9818a16&lt;SEP&gt;chunk-c99964a997545fd96cbae2fac33e426b</data>
