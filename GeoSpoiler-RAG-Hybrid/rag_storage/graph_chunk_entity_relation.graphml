</edge>
<edge source="József Orbán" target="Delamit Kft">
  <data key="d8">1.0</data>
  <data key="d9">József Orbán is the owner and head of Delamit Kft, a company tied to his stone quarry in Gánt, which is cited as the source of funding for the Hatvanpusta estate.</data>
  <data key="d10">leadership,ownership</data>
