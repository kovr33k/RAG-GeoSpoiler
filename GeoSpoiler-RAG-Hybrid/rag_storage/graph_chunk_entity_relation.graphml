</node>
<node id="Economic Crisis">
  <data key="d0">Economic Crisis</data>
  <data key="d1">event</data>
  <data key="d2">The economic crisis is a major historical threat to Europe, described as approaching due to current policies and the continuation of sanctions against Russian energy.</data>
  <data key="d3">chunk-d9aedd80ca30611f4314d3afe2ee2ad0</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\123.txt</data>
