</edge>
<edge source="Арбанк" target="Семён Могилевич">
  <data key="d8">1.0</data>
  <data key="d9">Семён Могилевич is believed by the speaker to have been a main sponsor of Арбанк, providing financial support that enabled Арбанк’s political rise.</data>
  <data key="d10">funding,political support,sponsorship</data>
