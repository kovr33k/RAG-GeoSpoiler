<edge source="Пинтер Шандер" target="Эзрадеш Венгри">
  <data key="d8">1.0</data>
  <data key="d9">Эзрадеш Венгри, a high-ranking investigator, identified Пинтер Шандер as the biggest criminal in Hungary and suggested the speaker could provide evidence against him.</data>
  <data key="d10">accusation,investigation</data>
