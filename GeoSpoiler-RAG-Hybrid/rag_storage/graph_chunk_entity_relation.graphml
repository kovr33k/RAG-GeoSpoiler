  <data key="d6"></data>
</node>
<node id="Эзрадеш Венгри">
  <data key="d0">Эзрадеш Венгри</data>
  <data key="d1">person</data>
  <data key="d2">Эзрадеш Венгри is a high-ranking investigator in Hungary, holding a rank equivalent to colonel, who informed the speaker that Пинтер Шандер is widely known as the biggest criminal in Hungary.</data>
  <data key="d3">chunk-85ab176e3cbddf97c2d5cd15191ff861</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
