  <data key="d6"></data>
</node>
<node id="Johann von Leers">
  <data key="d0">Johann von Leers</data>
  <data key="d1">person</data>
  <data key="d2">Johann von Leers was a Nazi SS-Sturmbannführer and radical anti-Semitic publicist who later converted to Islam, taking the name Omar Amin, fled to Argentina, and worked for Gamal Abdel Nasser.</data>
  <data key="d3">chunk-4c0e45973e2056f2a0c6c6cf9df17553</data>
