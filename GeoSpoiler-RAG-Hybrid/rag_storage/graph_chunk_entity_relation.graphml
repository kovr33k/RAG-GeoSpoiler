</edge>
<edge source="Витька" target="Leather Bag">
  <data key="d8">1.0</data>
  <data key="d9">The leather bag was used by the speaker to deliver money to Витька during routine, non-verbal transactions.</data>
  <data key="d10">funding delivery</data>
  <data key="d11">chunk-ac226d815cf8e5ee5f29617fff9c6877</data>
