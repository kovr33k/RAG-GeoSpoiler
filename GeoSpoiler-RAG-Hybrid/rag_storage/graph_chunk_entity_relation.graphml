</node>
<node id="Кома">
  <data key="d0">Кома</data>
  <data key="d1">event</data>
  <data key="d2">Кома is a medical event experienced by the speaker, after which police inquired about the perpetrators of violence against them.</data>
  <data key="d3">chunk-6ed5a8ece2f6bc4017c8fae3014bc239</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
