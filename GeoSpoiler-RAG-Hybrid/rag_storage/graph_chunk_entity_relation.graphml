</node>
<node id="тюрьма">
  <data key="d0">тюрьма</data>
  <data key="d1">location</data>
  <data key="d2">тюрьма is the prison facility where individuals associated with Шандор Пинтер, including Портик and Тони Дюри Визовицкий Ласлоу, were incarcerated.</data>
  <data key="d3">chunk-6ed5a8ece2f6bc4017c8fae3014bc239</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
