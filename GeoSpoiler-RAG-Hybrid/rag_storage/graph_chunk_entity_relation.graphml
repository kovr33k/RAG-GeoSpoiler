</node>
<node id="Danko">
  <data key="d0">Danko</data>
  <data key="d1">person</data>
  <data key="d2">Danko is a Slovak political figure whom Hungarian Foreign Minister Sándor Pintér urged Russian officials to support in order to form a parliamentary majority.</data>
  <data key="d3">chunk-a55a1b2f7d86f155201f7562a7195495</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\101.txt</data>
