</edge>
<edge source="Kremlin" target="Russian Orthodox Church">
  <data key="d8">1.0</data>
  <data key="d9">The Russian Orthodox Church acts as an instrument of the Kremlin’s foreign intelligence apparatus, promoting ideological influence abroad.</data>
  <data key="d10">covert operation,instrument</data>
