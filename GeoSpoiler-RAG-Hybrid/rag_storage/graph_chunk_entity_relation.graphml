<node id="Мадьяр">
  <data key="d0">Мадьяр</data>
  <data key="d1">person</data>
  <data key="d2">Мадьяр is a political figure and the main opponent of Orbán in the elections.</data>
  <data key="d3">chunk-cef394908f978f54c9d7b18dd4c332a7</data>
