</node>
<node id="Ervin Nadem">
  <data key="d0">Ervin Nadem</data>
  <data key="d1">person</data>
  <data key="d2">Ervin Nadem is a member of the Hungarian opposition party "Tisza" who was targeted by Russian disinformation campaigns involving fabricated reports of assault.</data>
  <data key="d3">chunk-325a7fb30b39d268db124a71f1e8acc7</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\96.txt</data>
