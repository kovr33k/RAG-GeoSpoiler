  <data key="d14"></data>
</edge>
<edge source="Арбанк" target="Spring 1998 Elections">
  <data key="d8">1.0</data>
  <data key="d9">The Spring 1998 Elections resulted in Арбанк coming to power, which triggered shifts in personal relationships and financial dynamics.</data>
  <data key="d10">political ascension</data>
  <data key="d11">chunk-ac226d815cf8e5ee5f29617fff9c6877</data>
