  <data key="d6"></data>
</node>
<node id="Ulrich Ziegmund">
  <data key="d0">Ulrich Ziegmund</data>
  <data key="d1">person</data>
  <data key="d2">Ulrich Ziegmund is the main candidate for the AfD's state branch in Saxony-Anhalt, accused of securing a high-paying position for his father within the party's parliamentary environment, with an annual salary exceeding 90,000 euros.</data>
  <data key="d3">chunk-b328e8d4304c0d0b1c17749a4f9e42bf</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\13.txt</data>
