</node>
<node id="speaker">
  <data key="d0">speaker</data>
  <data key="d1">person</data>
  <data key="d2">The speaker is a person who was the victim of violence, experienced a coma, refused to identify perpetrators to police, and later observed the consequences of Шандор Пинтер’s crackdown on criminal figures.</data>
  <data key="d3">chunk-6ed5a8ece2f6bc4017c8fae3014bc239</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
  <data key="d5">1777936114</data>
  <data key="d6"></data>
</node>
<node id="Саша">
  <data key="d0">Саша</data>
  <data key="d1">person</data>
  <data key="d2">Саша is a businessman and childhood friend of the speaker, who was described by Игорь as unimportant despite the speaker’s friendship with him.</data>
  <data key="d3">chunk-895d4fd828feac0cdb06b4f9b74dd90d</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
  <data key="d5">1777936114</data>
  <data key="d6"></data>
</node>
<node id="Октогон">
  <data key="d0">Октогон</data>
  <data key="d1">location</data>
  <data key="d2">Октогон is a central location in Budapest where the speaker met a young associate of Игорь.</data>
  <data key="d3">chunk-895d4fd828feac0cdb06b4f9b74dd90d</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
