</edge>
<edge source="Mádiár" target="Soros">
  <data key="d8">1.0</data>
  <data key="d9">Mádiár explicitly distanced himself from being labeled a Soros-funded opposition figure, reinforcing his credibility as a genuine insider exposing corruption from within.</data>
  <data key="d10">rejection_of_false_narrative</data>
  <data key="d11">chunk-49d9496e943d94ccc071cf105396b990</data>
