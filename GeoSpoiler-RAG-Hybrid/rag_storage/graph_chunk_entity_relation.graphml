<node id="Hlas">
  <data key="d0">Hlas</data>
  <data key="d1">organization</data>
  <data key="d2">Hlas is the political party founded by Peter Pellegrini.&lt;SEP&gt;Hlas is a political party in Slovakia described as a pro-European spoiler and a Kremlin project.&lt;SEP&gt;Hlas is a political party in Slovakia whose rating is approaching the 5% threshold.</data>
  <data key="d3">chunk-11b9d96fc698fa7b9242168a7bad3295&lt;SEP&gt;chunk-a55a1b2f7d86f155201f7562a7195495&lt;SEP&gt;chunk-09de750ab096b64385f95a95c7d0e5ad</data>
