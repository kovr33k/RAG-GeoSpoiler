  <data key="d0">Тони Дюри Визовицкий Ласлоу</data>
  <data key="d1">person</data>
  <data key="d2">Тони Дюри Визовицкий Ласлоу is a person who worked with Шандор Пинтер and was imprisoned for associations with the criminal underworld in the 1990s.</data>
  <data key="d3">chunk-6ed5a8ece2f6bc4017c8fae3014bc239</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
