</node>
<node id="István Hofman">
  <data key="d0">István Hofman</data>
  <data key="d1">person</data>
  <data key="d2">István Hofman was the first associate of József Pristash; he survived a bombing that burned 60% of his body and was connected to payments made to Igor.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
