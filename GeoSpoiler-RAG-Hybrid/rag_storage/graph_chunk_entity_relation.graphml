  <data key="d0">Бургермейштержолт</data>
  <data key="d1">person</data>
  <data key="d2">Бургермейштержолт is a young investigator aged 35 who reacted with fear when confronted with information about Пинтер Шандер.</data>
  <data key="d3">chunk-85ab176e3cbddf97c2d5cd15191ff861</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
  <data key="d5">1777936114</data>
  <data key="d6"></data>
</node>
<node id="НВС">
  <data key="d0">НВС</data>
  <data key="d1">organization</data>
  <data key="d2">НВС (Немзтведелмилгат) is a national interest protection unit created by Пинтер Шандер, described as analogous to an internal KGB.</data>
  <data key="d3">chunk-85ab176e3cbddf97c2d5cd15191ff861</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
