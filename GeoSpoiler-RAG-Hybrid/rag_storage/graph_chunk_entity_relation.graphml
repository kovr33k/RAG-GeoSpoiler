<node id="Dietmar Klaud">
  <data key="d0">Dietmar Klaud</data>
  <data key="d1">person</data>
  <data key="d2">Dietmar Klaud is a person who lived in Szentendre, received money deliveries from the speaker, and allegedly passed money to Orbán.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
