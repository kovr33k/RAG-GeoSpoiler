  <data key="d5">1777937381</data>
  <data key="d6"></data>
</node>
<node id="András Telekesh">
  <data key="d0">András Telekesh</data>
  <data key="d1">person</data>
  <data key="d2">András Telekesh is a former deputy head of Hungarian foreign intelligence who warns that Fidesz is panicking and may take reckless actions to retain power, with Russian support being critical to Orbán’s survival.</data>
  <data key="d3">chunk-583ccb318ed3bd5eb71b569940315d4f</data>
