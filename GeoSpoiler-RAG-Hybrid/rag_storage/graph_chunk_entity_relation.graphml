<node id="Sándor Pintér">
  <data key="d0">Sándor Pintér</data>
  <data key="d1">person</data>
  <data key="d2">Sándor Pintér is the Hungarian Minister of Foreign Affairs who is accused of transmitting confidential information to the Kremlin during EU Council meetings and reporting to Sergey Lavrov.</data>
  <data key="d3">chunk-a55a1b2f7d86f155201f7562a7195495</data>
