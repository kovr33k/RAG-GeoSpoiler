  <data key="d0">Leonid Stitsyura</data>
  <data key="d1">person</data>
  <data key="d2">Leonid Stitsyura is a person of Jewish origin, a member of a criminal group, who was protected by Seva from Igor Korol's retribution after severely injuring a mother of three.</data>
  <data key="d3">chunk-42453f70a393d3fdaae19dd559f506ab</data>
