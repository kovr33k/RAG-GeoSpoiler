<node id="Sweden">
  <data key="d0">Sweden</data>
  <data key="d1">country</data>
  <data key="d2">Sweden is a European country that operates S102B intelligence aircraft.&lt;SEP&gt;Sweden is a country whose armed forces are acquiring satellite capabilities to enhance its intelligence capabilities.</data>
