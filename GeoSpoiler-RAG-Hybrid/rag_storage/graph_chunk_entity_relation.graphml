</edge>
<edge source="Viktor Orbán" target="József Orbán">
  <data key="d8">1.0</data>
  <data key="d9">Viktor Orbán claims that the Hatvanpusta estate was built using revenues from his father József Orbán’s business, using this familial connection to deflect accusations of personal wealth.</data>
  <data key="d10">family relationship,ownership justification</data>
  <data key="d11">chunk-fc1feb8e698e39594612de628b9b30f8</data>
  <data key="d12">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\140.txt</data>
