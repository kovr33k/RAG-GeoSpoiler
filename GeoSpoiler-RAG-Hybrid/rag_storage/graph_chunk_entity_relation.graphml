  <data key="d0">François Genoud</data>
  <data key="d1">person</data>
  <data key="d2">François Genoud was a Swiss banker who held Nazi views, financed the defense of Adolf Eichmann, supported Islamist groups, and was associated with the promotion of extremist ideologies.</data>
  <data key="d3">chunk-4c0e45973e2056f2a0c6c6cf9df17553</data>
