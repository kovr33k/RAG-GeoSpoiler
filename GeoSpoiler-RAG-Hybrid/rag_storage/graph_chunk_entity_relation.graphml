  <data key="d8">1.0</data>
  <data key="d9">No direct relationship is stated or implied between Alexander Kirichanin and Pinter.</data>
  <data key="d10">no_relationship</data>
  <data key="d11">chunk-9eb97f8c573cf721a0206d7b0dff7868</data>
