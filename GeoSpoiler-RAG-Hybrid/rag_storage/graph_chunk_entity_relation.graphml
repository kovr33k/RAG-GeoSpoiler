<node id="Кир Стармер">
  <data key="d0">Кир Стармер</data>
  <data key="d1">person</data>
  <data key="d2">Кир Стармер is the Prime Minister of the United Kingdom who advocates for deeper EU-UK defense and economic cooperation.</data>
  <data key="d3">chunk-adcce0ecbb12090a19fa597edabfada4</data>
