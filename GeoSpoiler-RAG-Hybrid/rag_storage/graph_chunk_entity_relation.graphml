  <data key="d5">1777937381</data>
  <data key="d6"></data>
</node>
<node id="European Council">
  <data key="d0">European Council</data>
  <data key="d1">organization</data>
  <data key="d2">European Council is an institution of the European Union whose chairperson called on Viktor Orbán to honor an agreement regarding a loan to Ukraine.&lt;SEP&gt;The European Council, represented by its president Antonio Costa, is mentioned as having appealed to Ukraine, but its calls are portrayed as ineffective in stopping Ukrainian attacks on Russian energy infrastructure.</data>
  <data key="d3">chunk-870499425ae897e4d4a7fe9c0c2b515c&lt;SEP&gt;chunk-204b60f8b5f56bb209e8ca6cc9af48f9</data>
