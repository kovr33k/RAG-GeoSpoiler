</edge>
<edge source="Hatvanpusta" target="Akashhadhazi">
  <data key="d8">1.0</data>
  <data key="d9">Akashhadhazi, using his pilot license and media team, documented the Hatvanpusta estate from the air, revealing its luxury features and sparking public scrutiny.</data>
  <data key="d10">exposure,investigation</data>
  <data key="d11">chunk-fc1feb8e698e39594612de628b9b30f8</data>
