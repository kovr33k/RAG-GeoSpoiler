<node id="Friendship Oil Pipeline">
  <data key="d0">Friendship Oil Pipeline</data>
  <data key="d1">location</data>
  <data key="d2">Friendship Oil Pipeline is a strategic oil infrastructure that Hungary demands be restored for oil deliveries.</data>
  <data key="d3">chunk-bf3c850f2801bc7e22334b0ebc4ddaab</data>
