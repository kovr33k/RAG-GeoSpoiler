</node>
<node id="Pinter">
  <data key="d0">Pinter</data>
  <data key="d1">person</data>
  <data key="d2">Pinter was a person who wanted to buy real estate from Yozhef Pristsh and ordered his murder.</data>
  <data key="d3">chunk-e2abfcb6857ea1af89a247d75437a98e</data>
  <data key="d4">C:\WikiRag\RAG-GeoSpoiler\GeoSpoiler-RAG-Hybrid\output\normalized\Венгрия Словакия\134.txt</data>
