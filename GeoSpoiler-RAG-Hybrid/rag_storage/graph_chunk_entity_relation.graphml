</edge>
<edge source="Viktor Orbán" target="Mádiár">
  <data key="d8">1.0</data>
  <data key="d9">Mádiár, a former insider, publicly exposed Viktor Orbán’s corruption, including the misappropriation of funds and hidden assets, breaking the silence of the system he once served.</data>
  <data key="d10">corruption,exposure,insider_revelation</data>
  <data key="d11">chunk-49d9496e943d94ccc071cf105396b990</data>
