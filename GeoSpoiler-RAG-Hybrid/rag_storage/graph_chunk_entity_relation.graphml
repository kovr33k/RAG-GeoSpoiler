<node id="Björn Höcke">
  <data key="d0">Björn Höcke</data>
  <data key="d1">person</data>
  <data key="d2">Björn Höcke is a committed pro-Russian member of AfD who was involved in a conflict with Rüdiger Lukassen.</data>
  <data key="d3">chunk-c748c9a23ba05cffbc5245984ffc52e3</data>
