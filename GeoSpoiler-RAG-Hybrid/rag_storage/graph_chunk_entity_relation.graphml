  <data key="d14"></data>
</edge>
<edge source="László Kócs" target="Alexander Kirichanin">
  <data key="d8">1.0</data>
  <data key="d9">László Kócs and Alexander Kirichanin co-founded and operated a legal alcohol and beverage distribution business between Hungary and Ukraine.</data>
  <data key="d10">business partnership</data>
  <data key="d11">chunk-eb8a98bd952f81cd62fe86510f901918</data>
