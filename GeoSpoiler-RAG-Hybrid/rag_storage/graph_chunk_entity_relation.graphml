</node>
<node id="Department of Active Measures">
  <data key="d0">Department of Active Measures</data>
  <data key="d1">organization</data>
  <data key="d2">The Department of Active Measures is a division of the Russian Foreign Intelligence Service (SVR) responsible for political influence operations, including the drafting of the "Gamechanger" strategy.</data>
  <data key="d3">chunk-583ccb318ed3bd5eb71b569940315d4f</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\95.txt</data>
