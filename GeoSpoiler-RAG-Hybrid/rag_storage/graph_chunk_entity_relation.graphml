  <data key="d6"></data>
</node>
<node id="Andrei Kirienko">
  <data key="d0">Andrei Kirienko</data>
  <data key="d1">person</data>
  <data key="d2">Andrei Kirienko is a Russian official who previously attempted operations in Moldova and may have adopted a more cautious approach following that failure.</data>
  <data key="d3">chunk-8fa6adba441e776b293e92361b9880d1</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\140.txt</data>
