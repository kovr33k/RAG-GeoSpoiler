  <data key="d5">1777936517</data>
  <data key="d6"></data>
</node>
<node id="Zoltan Andre">
  <data key="d0">Zoltan Andre</data>
  <data key="d1">person</data>
  <data key="d2">Zoltan Andre is a staff member of Hungarian military intelligence who coordinated an espionage network in Zakarpattia, recruited a former Ukrainian military personnel, and conducted intelligence and sabotage activities against Ukraine from 2021, previously operating under diplomatic cover in Georgia from 2016 to 2020.</data>
  <data key="d3">chunk-d66247a37e4df218b0d4f4b7d7bea3c4</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\99.txt</data>
