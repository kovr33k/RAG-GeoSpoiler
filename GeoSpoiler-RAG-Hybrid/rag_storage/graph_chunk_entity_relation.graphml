</node>
<node id="Sanctions">
  <data key="d0">Sanctions</data>
  <data key="d1">other</data>
  <data key="d2">Sanctions are measures imposed against Russian energy, which Viktor Orbán and Dmitriev argue must be immediately lifted to prevent economic and energy collapse in Europe.</data>
  <data key="d3">chunk-d9aedd80ca30611f4314d3afe2ee2ad0</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\123.txt</data>
