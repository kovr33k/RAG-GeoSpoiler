</node>
<node id="Lotsi">
  <data key="d0">Lotsi</data>
  <data key="d1">person</data>
  <data key="d2">Lotsi is a person referenced by Seva as a courier to deliver money to "Vitek" (Viktor Orban).</data>
  <data key="d3">chunk-42453f70a393d3fdaae19dd559f506ab</data>
