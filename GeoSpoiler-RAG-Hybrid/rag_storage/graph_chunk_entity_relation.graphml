  <data key="d0">Укрэнерго</data>
  <data key="d1">organization</data>
  <data key="d2">Укрэнерго is a Ukrainian operator that had a contract for emergency power supply with Slovakia's power transmission system.</data>
  <data key="d3">chunk-b2842b9c04cc247c5969a9739ff25b33</data>
