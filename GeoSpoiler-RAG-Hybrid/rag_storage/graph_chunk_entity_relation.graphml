</edge>
<edge source="Kremlin" target="Sergei Kirienko">
  <data key="d8">1.0</data>
  <data key="d9">The Kremlin deployed Sergei Kirienko to lead Russian influence operations in Hungary, building on his prior work in Moldova and Romania.</data>
  <data key="d10">coordination,deployment,leadership</data>
  <data key="d11">chunk-95251bcfc4d08a0a36c341b9a9e2da54</data>
