  <data key="d0">GUR</data>
  <data key="d1">organization</data>
  <data key="d2">GUR (Main Intelligence Directorate of Ukraine) is a Ukrainian military intelligence organization that reported on North Korean troop activities in Russia.</data>
  <data key="d3">chunk-ec36c3f34e874fb6a0c44b533c707cfe</data>
