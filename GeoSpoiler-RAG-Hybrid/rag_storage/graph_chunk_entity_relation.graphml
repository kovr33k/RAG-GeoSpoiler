</node>
<node id="Мартин Магат">
  <data key="d0">Мартин Магат</data>
  <data key="d1">person</data>
  <data key="d2">Мартин Магат is the general director of a company who explained that the government decided to terminate a contract for emergency power supply with Ukraine's operator.</data>
  <data key="d3">chunk-b2842b9c04cc247c5969a9739ff25b33</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\36.txt</data>
