  <data key="d6"></data>
</node>
<node id="KGB">
  <data key="d0">KGB</data>
  <data key="d1">organization</data>
  <data key="d2">The KGB is the former Soviet security agency that developed the concept of active measures, later inherited and used by Russian intelligence services.</data>
  <data key="d3">chunk-8fa6adba441e776b293e92361b9880d1</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\140.txt</data>
  <data key="d5">1777936505</data>
  <data key="d6"></data>
</node>
<node id="SVR">
  <data key="d0">SVR</data>
  <data key="d1">organization</data>
  <data key="d2">SVR is the Russian foreign intelligence service that drafted a classified plan in February titled "Gamechanger," proposing a staged assassination attempt on Viktor Orbán to manipulate public opinion.&lt;SEP&gt;The SVR is the Russian foreign intelligence service that drafted a plan involving staged political incidents in Hungary, later rejected by the Kremlin.</data>
  <data key="d3">chunk-8fa6adba441e776b293e92361b9880d1&lt;SEP&gt;chunk-3da3b046ca1fff9119eaf735e34f56d4</data>
