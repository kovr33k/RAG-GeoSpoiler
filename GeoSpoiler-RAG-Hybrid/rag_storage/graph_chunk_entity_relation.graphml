<node id="April Elections">
  <data key="d0">April Elections</data>
  <data key="d1">event</data>
  <data key="d2">The April elections are a political event in Hungary where opposition parties are considering withdrawing to consolidate support against Fidesz.</data>
  <data key="d3">chunk-2886b7cb500c955cf1d8671ed22bd946</data>
