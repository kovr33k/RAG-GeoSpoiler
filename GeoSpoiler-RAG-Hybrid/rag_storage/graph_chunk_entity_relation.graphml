  <data key="d0">Government Information Center</data>
  <data key="d1">organization</data>
  <data key="d2">Government Information Center issued a statement regarding the group of deported individuals, noting their military backgrounds and activities.</data>
  <data key="d3">chunk-350a5144d8e2787035e85988d9818a16</data>
