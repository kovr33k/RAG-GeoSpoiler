<node id="Rüdiger Lukassen">
  <data key="d0">Rüdiger Lukassen</data>
  <data key="d1">person</data>
  <data key="d2">Rüdiger Lukassen is a former defense policy spokesperson for AfD who stepped down after a conflict with Björn Höcke.</data>
  <data key="d3">chunk-c748c9a23ba05cffbc5245984ffc52e3</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\27.txt</data>
