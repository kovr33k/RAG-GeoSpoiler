  <data key="d14"></data>
</edge>
<edge source="Kremlin" target="Moldova">
  <data key="d8">1.0</data>
  <data key="d9">The Kremlin conducted an influence operation in Moldova through Sergei Kirienko to prevent Maia Sandu’s re-election, which ultimately failed.</data>
  <data key="d10">election interference,influence operation</data>
  <data key="d11">chunk-95251bcfc4d08a0a36c341b9a9e2da54</data>
