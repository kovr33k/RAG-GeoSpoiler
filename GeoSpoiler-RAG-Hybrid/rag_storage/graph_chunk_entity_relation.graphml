</edge>
<edge source="Viktor Orbán" target="Judit Varga">
  <data key="d8">1.0</data>
  <data key="d9">Judit Varga, as Minister of Justice, was a key figure in Viktor Orbán’s inner circle and participated in efforts to suppress corruption investigations.</data>
  <data key="d10">close_associate,political_alliance</data>
  <data key="d11">chunk-49d9496e943d94ccc071cf105396b990</data>
