</node>
<node id="Арбан">
  <data key="d0">Арбан</data>
  <data key="d1">person</data>
  <data key="d2">Арбан is a person who came to power alongside Орбан and supported the criminal groups that were later targeted by Шандор Пинтер.</data>
  <data key="d3">chunk-6ed5a8ece2f6bc4017c8fae3014bc239</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
