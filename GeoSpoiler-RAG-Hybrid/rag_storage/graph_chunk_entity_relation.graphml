  <data key="d5">1777932957</data>
  <data key="d6"></data>
</node>
<node id="Izvestia">
  <data key="d0">Izvestia</data>
  <data key="d1">organization</data>
  <data key="d2">Izvestia is a Russian state newspaper where Markus Frömmel's wife previously worked as a journalist.</data>
  <data key="d3">chunk-b328e8d4304c0d0b1c17749a4f9e42bf</data>
