  <data key="d0">McDonald's</data>
  <data key="d1">organization</data>
  <data key="d2">McDonald's is a restaurant location near where an explosion occurred in central Budapest.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
