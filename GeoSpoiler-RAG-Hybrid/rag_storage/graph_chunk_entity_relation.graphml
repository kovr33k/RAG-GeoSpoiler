<node id="Francois Genoud">
  <data key="d0">Francois Genoud</data>
  <data key="d1">person</data>
  <data key="d2">Francois Genoud was a Swiss banker who held Nazi views, financed the defense of Adolf Eichmann, and supported Islamist groups.</data>
