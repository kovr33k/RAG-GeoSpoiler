<node id="Jan Kuciak">
  <data key="d0">Jan Kuciak</data>
  <data key="d1">person</data>
  <data key="d2">Jan Kuciak was a Slovak journalist murdered alongside his fiancée, leading to a scandal that temporarily removed Robert Fico from leadership of SMER.</data>
  <data key="d3">chunk-a55a1b2f7d86f155201f7562a7195495</data>
