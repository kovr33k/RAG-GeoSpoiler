<node id="1998 Hungarian Elections">
  <data key="d0">1998 Hungarian Elections</data>
  <data key="d1">event</data>
  <data key="d2">The 1998 Hungarian elections were won by Viktor Orban, leading to public outrage over crime and a subsequent government crackdown.</data>
  <data key="d3">chunk-6ed5a8ece2f6bc4017c8fae3014bc239</data>
