<node id="Roma People">
  <data key="d0">Roma People</data>
  <data key="d1">other</data>
  <data key="d2">Roma people are an ethnic minority group in Hungary, one of the community representatives mentioned in the report who was pressured to withdraw from an election.</data>
  <data key="d3">chunk-26fcbf6510a404d136a66a46e0584357</data>
