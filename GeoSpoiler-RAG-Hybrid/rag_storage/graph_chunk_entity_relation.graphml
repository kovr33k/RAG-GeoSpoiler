<node id="Szazalombatta Oil Refinery">
  <data key="d0">Szazalombatta Oil Refinery</data>
  <data key="d1">location</data>
  <data key="d2">Szazalombatta Oil Refinery is a Hungarian oil processing facility that is being guarded by military personnel against perceived Ukrainian threats.</data>
  <data key="d3">chunk-bf3c850f2801bc7e22334b0ebc4ddaab</data>
