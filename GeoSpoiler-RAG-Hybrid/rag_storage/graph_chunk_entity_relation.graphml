</node>
<node id="1956">
  <data key="d0">1956</data>
  <data key="d1">event</data>
  <data key="d2">1956 refers to the Hungarian Uprising, commemorated on its 70th anniversary in the context of national resistance to foreign influence.</data>
  <data key="d3">chunk-b2025a50f1328b82f061a4942a8dd453</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\50.txt</data>
