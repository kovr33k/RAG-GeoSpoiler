</node>
<node id="Ukrainian Defense Forces">
  <data key="d0">Ukrainian Defense Forces</data>
  <data key="d1">military_unit</data>
  <data key="d2">The Ukrainian Defense Forces are the military organization whose deployment and air defense positions were targeted for intelligence gathering by the Hungarian espionage network in western Ukraine.</data>
  <data key="d3">chunk-d66247a37e4df218b0d4f4b7d7bea3c4</data>
