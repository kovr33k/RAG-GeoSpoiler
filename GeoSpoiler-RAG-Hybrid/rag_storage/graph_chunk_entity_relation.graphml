<node id="Bundestag">
  <data key="d0">Bundestag</data>
  <data key="d1">organization</data>
  <data key="d2">Bundestag is the federal parliament of Germany where AfD has a parliamentary group, and where Markus Frömmel serves as deputy chairperson and where his wife works as an office manager for an AfD member of parliament.</data>
  <data key="d3">chunk-b328e8d4304c0d0b1c17749a4f9e42bf</data>
