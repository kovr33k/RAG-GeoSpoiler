<edge source="Viktor Orbán" target="Antal Rogán">
  <data key="d8">1.0</data>
  <data key="d9">Antal Rogán, a close associate of Viktor Orbán, is implicated in the cover-up of corruption evidence, as revealed in recordings involving Judit Varga.</data>
  <data key="d10">close_associate,corruption_coverup</data>
  <data key="d11">chunk-49d9496e943d94ccc071cf105396b990</data>
