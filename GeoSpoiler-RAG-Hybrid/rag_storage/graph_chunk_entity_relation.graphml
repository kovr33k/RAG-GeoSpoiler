  <data key="d0">Semion Mogilevich</data>
  <data key="d1">person</data>
  <data key="d2">Semion Mogilevich, also known as Igor Korol, is an organized crime figure whom the speaker only met in the company of Igor Korol.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
  <data key="d4">C:\WikiRag\RAG-GeoSpoiler\GeoSpoiler-RAG-Hybrid\output\normalized\Венгрия Словакия\134.txt</data>
