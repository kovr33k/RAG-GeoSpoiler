</edge>
<edge source="Viktor Orbán" target="Gáncs">
  <data key="d8">1.0</data>
  <data key="d9">The stone quarry business in Gáncs, owned by Dzsózsef Orbán, is cited as a source of revenue used to fund the hidden construction projects linked to Viktor Orbán’s wealth.</data>
  <data key="d10">asset_source</data>
