  <data key="d6"></data>
</node>
<node id="Berehove District">
  <data key="d0">Berehove District</data>
  <data key="d1">location</data>
  <data key="d2">Berehove District is a region in Ukraine from which Zoltan Andre recruited a former military serviceman to act as an agent in Zakarpattia.</data>
  <data key="d3">chunk-d66247a37e4df218b0d4f4b7d7bea3c4</data>
