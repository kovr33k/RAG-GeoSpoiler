  <data key="d0">Békásmegyer</data>
  <data key="d1">location</data>
  <data key="d2">Békásmegyer is a residential area in Szentendre where Dietmar Klaud is said to have rented an apartment.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
