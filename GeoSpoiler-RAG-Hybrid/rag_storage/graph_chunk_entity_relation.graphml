<edge source="Goldf Gim" target="László Kócs">
  <data key="d8">1.0</data>
  <data key="d9">László Kócs encountered Igor Korol and his associates again at Goldf Gim, a gym in Budapest, furthering their association.</data>
  <data key="d10">location of repeated interaction</data>
  <data key="d11">chunk-eb8a98bd952f81cd62fe86510f901918</data>
