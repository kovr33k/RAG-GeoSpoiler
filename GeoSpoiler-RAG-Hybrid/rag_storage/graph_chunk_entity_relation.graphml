<edge source="Операция «Будапешт»" target="Москва">
  <data key="d8">1.0</data>
  <data key="d9">Москва orchestrated the covert operation «Будапешт» to influence Hungary's parliamentary elections.</data>
  <data key="d10">covert_operation,orchestration</data>
