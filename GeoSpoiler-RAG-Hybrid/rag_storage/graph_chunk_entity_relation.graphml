  <data key="d5">1777938035</data>
  <data key="d6"></data>
</node>
<node id="General Prosecutor's Office of Slovakia">
  <data key="d0">General Prosecutor's Office of Slovakia</data>
  <data key="d1">organization</data>
  <data key="d2">The General Prosecutor's Office of Slovakia is the institution that accepted the complaint against Robert Fico and initiated a formal investigation into allegations of treason and abuse of power.</data>
  <data key="d3">chunk-0d2e8519cd0bab60a3e52b70a90d3f0b</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\103.txt</data>
