<node id="Gáspár Orbán">
  <data key="d0">Gáspár Orbán</data>
  <data key="d1">person</data>
  <data key="d2">Gáspár Orbán is the son of Hungarian Prime Minister Viktor Orbán and a former lieutenant in the Hungarian army who planned to send troops to Chad to protect local Christians, expecting a 50% casualty rate.</data>
  <data key="d3">chunk-791a0f308fdc4f1a500e850db6490862</data>
