</node>
<node id="Vác">
  <data key="d0">Vác</data>
  <data key="d1">location</data>
  <data key="d2">Vác is a city near Budapest, Hungary, where the speaker was transferred and later imprisoned.</data>
  <data key="d3">chunk-53047d8273819f991ab1b18d7532d438</data>
  <data key="d4">C:\WikiRag\RAG-GeoSpoiler\GeoSpoiler-RAG-Hybrid\output\normalized\Венгрия Словакия\134.txt</data>
