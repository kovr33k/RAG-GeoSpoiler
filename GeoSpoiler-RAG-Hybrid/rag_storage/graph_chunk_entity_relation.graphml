<edge source="Viktor Orbán" target="Delamit Kft.">
  <data key="d8">1.0</data>
  <data key="d9">Delamit Kft., owned by Dzsózsef Orbán, is suspected of providing the financial means to fund the hidden construction project linked to Viktor Orbán’s illicit assets.</data>
  <data key="d10">asset_concealment,financial_support</data>
  <data key="d11">chunk-49d9496e943d94ccc071cf105396b990</data>
