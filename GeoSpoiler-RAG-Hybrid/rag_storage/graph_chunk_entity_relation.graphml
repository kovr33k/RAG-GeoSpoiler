  <data key="d6"></data>
</node>
<node id="King">
  <data key="d0">King</data>
  <data key="d1">person</data>
  <data key="d2">King is a person who received money from Mogilevich and passed it to a witness.</data>
  <data key="d3">chunk-e2abfcb6857ea1af89a247d75437a98e</data>
