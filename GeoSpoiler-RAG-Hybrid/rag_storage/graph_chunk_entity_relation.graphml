<node id="Tino Chrupalla">
  <data key="d0">Tino Chrupalla</data>
  <data key="d1">person</data>
  <data key="d2">Tino Chrupalla is a co-chair of AfD who has employed the wife of a party colleague in his electoral district in Saxony for nearly ten years, confirming the employment but denying that his own wife works within AfD structures.</data>
  <data key="d3">chunk-b328e8d4304c0d0b1c17749a4f9e42bf</data>
