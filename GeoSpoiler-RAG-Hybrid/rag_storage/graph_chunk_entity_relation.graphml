<node id="Pavel Sorokin">
  <data key="d0">Pavel Sorokin</data>
  <data key="d1">person</data>
  <data key="d2">Pavel Sorokin is the Deputy Minister of Energy of the Russian Federation who was contacted by Siyarta to provide justification for removing sanctions positions from the EU's 18th sanctions package.</data>
  <data key="d3">chunk-2843e721f5be37e2778dd3123cdcec43</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\140.txt</data>
