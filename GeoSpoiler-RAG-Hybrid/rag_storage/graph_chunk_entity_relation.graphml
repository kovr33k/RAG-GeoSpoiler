</node>
<node id="Omar Amin">
  <data key="d0">Omar Amin</data>
  <data key="d1">person</data>
  <data key="d2">Omar Amin is the adopted Islamic name of Johann von Leers, a Nazi ideologue who converted to Islam.</data>
  <data key="d3">chunk-4c0e45973e2056f2a0c6c6cf9df17553</data>
  <data key="d4">C:\WikiRag\RAG-GeoSpoiler\GeoSpoiler-RAG-Hybrid\output\normalized\Ультра левые и ультра правые\23.txt</data>
