  <data key="d0">Yozef Rogoch</data>
  <data key="d1">person</data>
  <data key="d2">Yozef Rogoch was a citizen of Slovakia and the executor of the murder of Yozhef Pristsh.</data>
  <data key="d3">chunk-e2abfcb6857ea1af89a247d75437a98e</data>
