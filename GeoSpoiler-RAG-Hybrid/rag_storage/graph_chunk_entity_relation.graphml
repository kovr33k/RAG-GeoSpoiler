<node id="Kaja Kallas">
  <data key="d0">Kaja Kallas</data>
  <data key="d1">person</data>
  <data key="d2">Kaja Kallas is a person who expects Ukraine to win the war against Russia, as referenced in Орбан's statement.</data>
