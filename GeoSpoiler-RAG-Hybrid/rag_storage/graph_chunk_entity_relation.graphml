</edge>
<edge source="Семён Могилевич" target="Томаш Портик">
  <data key="d8">1.0</data>
  <data key="d9">Семён Могилевич and Томаш Портик were partners in the illicit fuel adulteration business known as Oyki Kish, operating under the leadership of Шандор Пинтер.</data>
  <data key="d10">criminal partnership,illicit business</data>
