</node>
<node id="David Bogatin">
  <data key="d0">David Bogatin</data>
  <data key="d1">person</data>
  <data key="d2">David Bogatin was an associate of Semen Mogilevich who met Donald Trump at Trump Tower in 1984 and purchased five luxury apartments in cash.</data>
  <data key="d3">chunk-5ccdb895c49cc5a1b4f5807c901e88cf</data>
