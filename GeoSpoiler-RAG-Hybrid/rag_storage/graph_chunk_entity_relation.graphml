<node id="Brexit">
  <data key="d0">Brexit</data>
  <data key="d1">event</data>
  <data key="d2">Brexit is the event of the United Kingdom's withdrawal from the European Union.</data>
  <data key="d3">chunk-ecbbaaa3d4427c7b635b0a400c28258a</data>
  <data key="d4">C:\WikiRag\RAG-GeoSpoiler\GeoSpoiler-RAG-Hybrid\output\normalized\Англия\2.txt</data>
