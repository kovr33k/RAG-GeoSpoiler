<node id="Gnessin Academy of Music">
  <data key="d0">Gnessin Academy of Music</data>
  <data key="d1">organization</data>
  <data key="d2">Gnessin Academy of Music is a musical institution in Moscow where Matthias Mözdorf holds the title of honorary professor.</data>
  <data key="d3">chunk-c748c9a23ba05cffbc5245984ffc52e3</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\27.txt</data>
