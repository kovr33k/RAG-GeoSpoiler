<node id="23 декабря 1998 года">
  <data key="d0">23 декабря 1998 года</data>
  <data key="d1">event</data>
  <data key="d2">23 декабря 1998 года is the date of a failed assassination attempt on the speaker in Budapest, occurring on the eve of Christmas.</data>
  <data key="d3">chunk-895d4fd828feac0cdb06b4f9b74dd90d</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
