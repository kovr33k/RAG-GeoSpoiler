</node>
<node id="Svinktor Torban">
  <data key="d0">Svinktor Torban</data>
  <data key="d1">person</data>
  <data key="d2">Svinktor Torban is an individual who published a video showing military personnel guarding a Hungarian oil refinery against alleged Ukrainian threats.</data>
  <data key="d3">chunk-bf3c850f2801bc7e22334b0ebc4ddaab</data>
