  <data key="d5">1777934202</data>
  <data key="d6"></data>
</node>
<node id="Marco Rubio">
  <data key="d0">Marco Rubio</data>
  <data key="d1">person</data>
  <data key="d2">Marco Rubio is the United States Secretary of State who publicly endorsed Viktor Orbán during a visit to Budapest.&lt;SEP&gt;Marco Rubio is the U.S. secretary of state who visited Budapest to campaign for Viktor Orbán.</data>
  <data key="d3">chunk-583ccb318ed3bd5eb71b569940315d4f&lt;SEP&gt;chunk-4219648b35dcbd430c607633467c92dc</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\95.txt&lt;SEP&gt;D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\189.txt</data>
  <data key="d5">1777937568</data>
  <data key="d6"></data>
</node>
<node id="Vance">
  <data key="d0">Vance</data>
  <data key="d1">person</data>
  <data key="d2">Vance is the Vice President of the United States who is scheduled to visit Hungary due to Donald Trump’s unavailability caused by the war in Iran.&lt;SEP&gt;Vance is the vice president of the United States who is scheduled to visit Hungary on 7–8 April to support Orbán.&lt;SEP&gt;Vance is a political figure who visited Hungary to support Orbán, an action some analysts believe negatively impacted Orbán’s polling numbers.</data>
  <data key="d3">chunk-583ccb318ed3bd5eb71b569940315d4f&lt;SEP&gt;chunk-81536517f133c3a5924be660cac3eb05&lt;SEP&gt;chunk-a810084503e65cb067ff1fc3c7a05189</data>
