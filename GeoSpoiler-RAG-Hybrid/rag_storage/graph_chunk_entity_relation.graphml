</node>
<node id="Сомбатхей">
  <data key="d0">Сомбатхей</data>
  <data key="d1">location</data>
  <data key="d2">Сомбатхей is a location in Hungary where the speaker was transferred after sentencing and spent time in quarantine due to COVID-19.</data>
  <data key="d3">chunk-85ab176e3cbddf97c2d5cd15191ff861</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
