<node id="Marcus Frontmeyer">
  <data key="d0">Marcus Frontmeyer</data>
  <data key="d1">person</data>
  <data key="d2">Marcus Frontmeyer is the current foreign policy spokesperson for a political faction, has been associated with Russian structures and described in media as a "fully controlled deputy," and has recently established contacts with U.S. Republicans.</data>
  <data key="d3">chunk-c748c9a23ba05cffbc5245984ffc52e3</data>
