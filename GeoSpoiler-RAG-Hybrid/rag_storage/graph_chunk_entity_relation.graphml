</node>
<node id="Portik Tomas">
  <data key="d0">Portik Tomas</data>
  <data key="d1">person</data>
  <data key="d2">Portik Tomas worked with Pinter and passed the order to eliminate Yozhef Pristsh to Yozef Rogoch.</data>
  <data key="d3">chunk-e2abfcb6857ea1af89a247d75437a98e</data>
