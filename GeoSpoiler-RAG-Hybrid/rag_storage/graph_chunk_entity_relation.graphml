  <data key="d13">1777936571</data>
  <data key="d14"></data>
</edge>
<edge source="Viktor Orbán" target="Hatvanpusta">
  <data key="d8">1.0</data>
  <data key="d9">Viktor Orbán denies personal ownership of Hatvanpusta, insisting it belongs to his father and remains unfinished, despite overwhelming evidence of its luxury and scale.</data>
  <data key="d10">denial of ownership,narrative defense</data>
