  <data key="d0">József Pristash</data>
  <data key="d1">person</data>
  <data key="d2">József Pristash is a person who was killed, and whose associate, István Hofman, later survived a bombing.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
