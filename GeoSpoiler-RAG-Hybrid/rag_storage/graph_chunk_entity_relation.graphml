<node id="Matthias Mözdorf">
  <data key="d0">Matthias Mözdorf</data>
  <data key="d1">person</data>
  <data key="d2">Matthias Mözdorf is a former foreign policy spokesperson for a political faction, represents a consistent pro-Russian line, and is an honorary professor at the Gnessin Academy of Music in Moscow.</data>
  <data key="d3">chunk-c748c9a23ba05cffbc5245984ffc52e3</data>
