<node id="U.S. Department of the Treasury">
  <data key="d0">U.S. Department of the Treasury</data>
  <data key="d1">organization</data>
  <data key="d2">U.S. Department of the Treasury is an organization that included Cuba in a list of countries prohibited from purchasing Russian oil.</data>
