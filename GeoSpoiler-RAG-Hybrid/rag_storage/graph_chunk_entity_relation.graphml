</node>
<node id="Igor">
  <data key="d0">Igor</data>
  <data key="d1">person</data>
  <data key="d2">Igor is a person who received money from István Hofman for roof payments and was present during interactions involving money transfers and bombings.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
