  <data key="d14"></data>
</edge>
<edge source="European Union" target="Péter Szijjártó">
  <data key="d8">1.0</data>
  <data key="d9">Péter Szijjártó conditioned Hungary’s support for Ukraine’s EU accession on specific language regarding national minorities, aiming to delay or block the process.</data>
  <data key="d10">conditional support,diplomatic negotiation</data>
