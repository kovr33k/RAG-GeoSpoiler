</edge>
<edge source="Viktor Orbán" target="SvR RF">
  <data key="d8">1.0</data>
  <data key="d9">SvR RF proposed Operation "GameChanger" to stage an assassination attempt on Viktor Orbán to boost his electoral prospects by shifting public sentiment toward emotional security narratives.</data>
  <data key="d10">assassination plot,intelligence operation,political manipulation</data>
  <data key="d11">chunk-325a7fb30b39d268db124a71f1e8acc7</data>
