  <data key="d6"></data>
</node>
<node id="BMW">
  <data key="d0">BMW</data>
  <data key="d1">other</data>
  <data key="d2">BMW is a car owned by the speaker, which was targeted during an assassination attempt and had a malfunctioning door lock.</data>
  <data key="d3">chunk-895d4fd828feac0cdb06b4f9b74dd90d</data>
