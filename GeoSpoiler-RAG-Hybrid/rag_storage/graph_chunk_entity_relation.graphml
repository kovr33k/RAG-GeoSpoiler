<node id="Юозас Олекас">
  <data key="d0">Юозас Олекас</data>
  <data key="d1">person</data>
  <data key="d2">Юозас Олекас is the Speaker of the Seimas of Lithuania, born in Siberian exile after his family's deportation during World War II, who emphasizes Lithuania’s historical trauma and its implications for national security policy.</data>
  <data key="d3">chunk-f1a89cef022ba72f7cec7e5ae7c29101</data>
