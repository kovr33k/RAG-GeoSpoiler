</node>
<node id="Gáspár Orbán">
  <data key="d0">Gáspár Orbán</data>
  <data key="d1">person</data>
  <data key="d2">Gáspár Orbán is the son of Hungarian Prime Minister Viktor Orbán and a former Hungarian Army captain (then lieutenant) who planned a military mission to Chad to protect Christians, expecting 50% casualty rates, motivated by claimed divine guidance.</data>
  <data key="d3">chunk-791a0f308fdc4f1a500e850db6490862</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\124.txt</data>
  <data key="d5">1777935370</data>
  <data key="d6"></data>
</node>
<node id="Sylvester Pálkinás">
  <data key="d0">Sylvester Pálkinás</data>
  <data key="d1">person</data>
  <data key="d2">Sylvester Pálkinás is a former Hungarian Army captain who studied with Gáspár Orbán at the Royal Military Academy Sandhurst and disclosed details of Gáspár’s planned mission to Chad in an interview with Telex.hu.</data>
  <data key="d3">chunk-791a0f308fdc4f1a500e850db6490862</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\124.txt</data>
  <data key="d5">1777935370</data>
  <data key="d6"></data>
</node>
<node id="Chad">
  <data key="d0">Chad</data>
  <data key="d1">country</data>
  <data key="d2">Chad is an African country where Gáspár Orbán planned a military mission to protect Christians, despite the projected high casualty rate among Hungarian soldiers.</data>
  <data key="d3">chunk-791a0f308fdc4f1a500e850db6490862</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\124.txt</data>
  <data key="d5">1777935370</data>
  <data key="d6"></data>
</node>
<node id="Royal Military Academy Sandhurst">
  <data key="d0">Royal Military Academy Sandhurst</data>
  <data key="d1">location</data>
  <data key="d2">Royal Military Academy Sandhurst is a British military academy where Gáspár Orbán and Sylvester Pálkinás studied together and discussed the planned mission to Chad.</data>
  <data key="d3">chunk-791a0f308fdc4f1a500e850db6490862</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\124.txt</data>
  <data key="d5">1777935370</data>
  <data key="d6"></data>
</node>
<node id="Telex.hu">
  <data key="d0">Telex.hu</data>
  <data key="d1">document</data>
  <data key="d2">Telex.hu is a Hungarian media outlet that published an interview with Sylvester Pálkinás revealing details of Gáspár Orbán’s planned military mission to Chad, which garnered approximately 1.5 million views.</data>
  <data key="d3">chunk-791a0f308fdc4f1a500e850db6490862</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\124.txt</data>
  <data key="d5">1777935370</data>
  <data key="d6"></data>
</node>
<node id="Hungarian Army">
  <data key="d0">Hungarian Army</data>
  <data key="d1">military_unit</data>
  <data key="d2">The Hungarian Army is the national military force of Hungary, of which Gáspár Orbán and Sylvester Pálkinás were members, and which was planned to be deployed in a mission to Chad.</data>
  <data key="d3">chunk-791a0f308fdc4f1a500e850db6490862</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\124.txt</data>
