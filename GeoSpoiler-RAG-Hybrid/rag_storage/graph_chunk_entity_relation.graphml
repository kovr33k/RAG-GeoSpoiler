<node id="Raúl Guillermo Rodríguez Castro">
  <data key="d0">Raúl Guillermo Rodríguez Castro</data>
  <data key="d1">person</data>
  <data key="d2">Raúl Guillermo Rodríguez Castro is the grandson of Cuban leader Raúl Castro and met with U.S. State Department officials during secret talks in Havana.</data>
  <data key="d3">chunk-07e1a126d8b8691b4020263f5c90fd4b</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Куба\8.txt</data>
