</node>
<node id="Szentendre">
  <data key="d0">Szentendre</data>
  <data key="d1">location</data>
  <data key="d2">Szentendre is a small city near Budapest where Dietmar Klaud lived in a large house, and where the speaker met him to deliver money.</data>
  <data key="d3">chunk-c338d5794d84977817897ee6bca1756e</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
