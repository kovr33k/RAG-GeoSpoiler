  <data key="d5">1780159088</data>
  <data key="d6"></data>
</node>
<node id="Cherep">
  <data key="d0">Cherep</data>
  <data key="d1">person</data>
  <data key="d2">Cherep was the original leader of the criminal group later led by Igor Korol.</data>
  <data key="d3">chunk-b107034176b638d6ed0508c3346f0725</data>
