<node id="BSW">
  <data key="d0">BSW</data>
  <data key="d1">organization</data>
  <data key="d2">BSW is a German political party whose 65% of voters firmly reject any assistance to Ukraine.</data>
  <data key="d3">chunk-9ed06713c000461ec66858856eef1a63</data>
