<edge source="Viktor Orbán" target="Donald Tusk">
  <data key="d8">1.0</data>
  <data key="d9">Donald Tusk publicly criticized Viktor Orbán for his communications with Vladimir Putin, using the leak to politically pressure Jarosław Kaczyński.</data>
  <data key="d10">political criticism,public challenge</data>
  <data key="d11">chunk-a3aab01d8a12e8135d55b3153fc006d0</data>
