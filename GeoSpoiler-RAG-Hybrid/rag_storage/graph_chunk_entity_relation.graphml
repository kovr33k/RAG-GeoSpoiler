</node>
<node id="Игорь Король">
  <data key="d0">Игорь Король</data>
  <data key="d1">person</data>
  <data key="d2">Игорь Король is a person who was imprisoned for 9 months, had a pregnant Hungarian girlfriend, and later became involved in criminal activities including extortion against Alexander Kirichanin.</data>
  <data key="d3">chunk-9eb97f8c573cf721a0206d7b0dff7868</data>
