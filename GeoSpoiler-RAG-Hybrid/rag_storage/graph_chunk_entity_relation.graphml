</edge>
<edge source="Viktor Orbán" target="Gamechanger">
  <data key="d8">1.0</data>
  <data key="d9">The "Gamechanger" strategy is a Russian intelligence plan designed to manipulate the Hungarian election by staging a simulated assassination attempt on Viktor Orbán to shift campaign dynamics.</data>
  <data key="d10">covert strategy,political manipulation</data>
  <data key="d11">chunk-583ccb318ed3bd5eb71b569940315d4f</data>
