<node id="Winston Churchill">
  <data key="d0">Winston Churchill</data>
  <data key="d1">person</data>
  <data key="d2">Winston Churchill is a former UK Prime Minister to whom Donald Trump compared Keir Starmer unfavorably.</data>
  <data key="d3">chunk-4528714a664b747f0d79d200f4e5d6ef</data>
  <data key="d4">C:\WikiRag\RAG-GeoSpoiler\GeoSpoiler-RAG-Hybrid\output\normalized\Англия\8.txt</data>
