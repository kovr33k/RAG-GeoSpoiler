  <data key="d0">Serbia</data>
  <data key="d1">country</data>
  <data key="d2">Serbia is a country whose partners are engaged in diplomatic discussions by the Hungarian Minister of Foreign Affairs outside European Union meetings.</data>
  <data key="d3">chunk-efac8eca24c7251212c13175865647fb</data>
