  <data key="d0">Motion of Censure</data>
  <data key="d1">event</data>
  <data key="d2">Motion of Censure is a radical legal instrument in the European Parliament that, if adopted, requires the resignation of the entire European Commission.</data>
  <data key="d3">chunk-a73e41ce47973ce6d0501f8f7acc0955</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\21.txt</data>
