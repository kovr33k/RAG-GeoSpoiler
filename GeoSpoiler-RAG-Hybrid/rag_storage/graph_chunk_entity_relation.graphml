  <data key="d0">Леонид Тюра</data>
  <data key="d1">person</data>
  <data key="d2">Леонид Тюра is a person who was imprisoned in Hungary for criminal activities in the 1990s and later became a citizen of Израиль.</data>
  <data key="d3">chunk-6ed5a8ece2f6bc4017c8fae3014bc239</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
