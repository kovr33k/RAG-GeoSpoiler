  <data key="d0">Siyarta</data>
  <data key="d1">person</data>
  <data key="d2">Siyarta is the Minister of Foreign Affairs of Hungary who engaged in discussions with Russian officials to facilitate the removal of sanctions against individuals linked to Russian oligarchs, and later claimed the conversations were normal diplomacy.</data>
  <data key="d3">chunk-2843e721f5be37e2778dd3123cdcec43</data>
