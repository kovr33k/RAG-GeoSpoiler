</node>
<node id="Sándor Pintér">
  <data key="d0">Sándor Pintér</data>
  <data key="d1">person</data>
  <data key="d2">Sándor Pintér is the Hungarian Minister of the Interior, whom the interrogators identified as their boss and who the speaker accuses of orchestrating the prison interrogations.</data>
  <data key="d3">chunk-53047d8273819f991ab1b18d7532d438</data>
  <data key="d4">C:\WikiRag\RAG-GeoSpoiler\GeoSpoiler-RAG-Hybrid\output\normalized\Венгрия Словакия\134.txt</data>
