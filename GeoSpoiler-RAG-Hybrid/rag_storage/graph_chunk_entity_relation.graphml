</edge>
<edge source="European Union" target="Mádiár">
  <data key="d8">1.0</data>
  <data key="d9">Mádiár’s revelations contrasted with Western narratives, emphasizing corruption in Hungary rather than blaming the European Union or foreign influence.</data>
  <data key="d10">anti_propaganda,funding_context</data>
