  <data key="d14"></data>
</edge>
<edge source="Kremlin" target="Peter Szijjártó">
  <data key="d8">1.0</data>
  <data key="d9">Peter Szijjártó maintained close ties with the Kremlin, visiting Moscow 16 times during the war and meeting Vladimir Putin personally.</data>
  <data key="d10">loyalty,political alignment</data>
  <data key="d11">chunk-e4089c9c991c6402b317d88ca6848ab9</data>
