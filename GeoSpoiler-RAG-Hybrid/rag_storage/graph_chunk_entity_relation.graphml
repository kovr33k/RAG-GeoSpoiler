<node id="Chișinău">
  <data key="d0">Chișinău</data>
  <data key="d1">location</data>
  <data key="d2">Chișinău is the capital of Moldova where Russian interference operations, including voter suppression and disinformation, were conducted prior to the 2023 elections.</data>
  <data key="d3">chunk-3da3b046ca1fff9119eaf735e34f56d4</data>
