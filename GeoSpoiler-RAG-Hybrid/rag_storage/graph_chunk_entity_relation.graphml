  <data key="d0">Gulbakhor Ismailova</data>
  <data key="d1">person</data>
  <data key="d2">Gulbakhor Ismailova is the sister of Alisher Usmanov, who was subject to EU sanctions and was successfully removed from the sanctions list after intervention by Russian and Hungarian officials.</data>
  <data key="d3">chunk-2843e721f5be37e2778dd3123cdcec43</data>
