<node id="Radев">
  <data key="d0">Radев</data>
  <data key="d1">person</data>
  <data key="d2">Radев has a single-party majority and does not require partners to form a coalition.</data>
  <data key="d3">chunk-1b86c9560ec7e43e68be30c2e38dbbde</data>
