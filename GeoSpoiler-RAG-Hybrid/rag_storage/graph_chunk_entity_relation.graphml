  <data key="d0">Gamal Abdel Nasser</data>
  <data key="d1">person</data>
  <data key="d2">Gamal Abdel Nasser was an Egyptian leader for whom Johann von Leers worked after converting to Islam and fleeing to Argentina.</data>
  <data key="d3">chunk-4c0e45973e2056f2a0c6c6cf9df17553</data>
