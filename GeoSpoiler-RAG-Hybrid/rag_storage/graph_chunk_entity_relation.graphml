<node id="Markus Frömmel">
  <data key="d0">Markus Frömmel</data>
  <data key="d1">person</data>
  <data key="d2">Markus Frömmel is a leading AfD candidate for Baden-Württemberg, deputy chair of the AfD parliamentary group in the Bundestag, and a close ally of Alice Weidel; his wife works as an office manager for an AfD member of parliament and previously worked as a journalist for the Russian state newspaper Izvestia.</data>
  <data key="d3">chunk-b328e8d4304c0d0b1c17749a4f9e42bf</data>
