  <data key="d0">Yozhef Pristsh</data>
  <data key="d1">person</data>
  <data key="d2">Yozhef Pristsh was a wealthy, stubborn real estate entrepreneur who was murdered.</data>
  <data key="d3">chunk-e2abfcb6857ea1af89a247d75437a98e</data>
