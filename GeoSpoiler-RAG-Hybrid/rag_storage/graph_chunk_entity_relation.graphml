<edge source="Viktor Orbán" target="Soviet Foreign Intelligence Service">
  <data key="d8">1.0</data>
  <data key="d9">The Soviet Foreign Intelligence Service developed the "Gamechanger" strategy to simulate an assassination attempt on Viktor Orbán to manipulate public perception and secure his electoral victory.</data>
  <data key="d10">covert strategy,influence operation,political support</data>
  <data key="d11">chunk-583ccb318ed3bd5eb71b569940315d4f</data>
