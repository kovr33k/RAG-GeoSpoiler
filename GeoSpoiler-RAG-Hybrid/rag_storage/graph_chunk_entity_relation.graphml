<node id="Johann von Leers">
  <data key="d0">Johann von Leers</data>
  <data key="d1">person</data>
  <data key="d2">Johann von Leers was a Nazi storm battalion leader who converted to Islam, adopting the name Omar Amin, fled to Argentina, worked for Gamal Abdel Nasser, and was a radical antisemitic propagandist under Adolf Hitler until his death.</data>
  <data key="d3">chunk-4c0e45973e2056f2a0c6c6cf9df17553</data>
