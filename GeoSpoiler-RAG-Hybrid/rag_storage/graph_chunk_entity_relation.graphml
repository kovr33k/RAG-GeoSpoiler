<edge source="Viktor Orban" target="1848 Uprising">
  <data key="d8">1.0</data>
  <data key="d9">Viktor Orban invokes the 1848 Uprising as a historical trauma to mobilize Hungarian public sentiment against perceived foreign domination.</data>
  <data key="d10">historical manipulation,rhetorical invocation</data>
