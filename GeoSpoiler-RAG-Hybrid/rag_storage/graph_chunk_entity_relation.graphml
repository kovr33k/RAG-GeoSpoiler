  <data key="d6"></data>
</node>
<node id="Вендис">
  <data key="d0">Вендис</data>
  <data key="d1">other</data>
  <data key="d2">Вендис was a cafeteria-like establishment near Октогон in Budapest, now reportedly closed.</data>
  <data key="d3">chunk-895d4fd828feac0cdb06b4f9b74dd90d</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Венгрия Словакия\134.txt</data>
