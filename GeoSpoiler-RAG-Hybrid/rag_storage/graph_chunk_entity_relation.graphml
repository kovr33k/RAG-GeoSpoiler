<node id="Зеленский">
  <data key="d0">Зеленский</data>
  <data key="d1">person</data>
  <data key="d2">Зеленский is a person who made a statement to POLITICO about Vladimir Putin's actions regarding European unity.</data>
  <data key="d3">chunk-78d9923aabbca45b70bc35cbb1701e26</data>
