<node id="Stefan Balliet">
  <data key="d0">Stefan Balliet</data>
  <data key="d1">person</data>
  <data key="d2">Stefan Balliet is a far-right extremist who attacked a synagogue in Halle in 2019 and was an admirer of Atomwaffen Division.</data>
  <data key="d3">chunk-4117a24ac776e64ee5b10c9c825a2778</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\22.txt</data>
