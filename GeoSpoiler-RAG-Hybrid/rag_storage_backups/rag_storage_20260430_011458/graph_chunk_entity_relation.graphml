  <data key="d6"></data>
</node>
<node id="Ультраправые">
  <data key="d0">Ультраправые</data>
  <data key="d1">organization</data>
  <data key="d2">Ультраправые are far-right populist political groups in Europe that Путин seeks to empower, believing they will be more amenable to Russian interests.</data>
  <data key="d3">chunk-fc81f47105f95a01062a3dca9ee5ad14</data>
