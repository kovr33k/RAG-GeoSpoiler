</node>
<node id="Halle">
  <data key="d0">Halle</data>
  <data key="d1">location</data>
  <data key="d2">Halle is a German city where Stefan Balliet carried out a synagogue attack in 2019, linked to Atomwaffen Division ideology.</data>
  <data key="d3">chunk-4117a24ac776e64ee5b10c9c825a2778</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\22.txt</data>
