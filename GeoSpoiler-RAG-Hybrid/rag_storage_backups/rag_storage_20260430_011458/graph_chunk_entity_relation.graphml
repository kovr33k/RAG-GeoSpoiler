  <data key="d6"></data>
</node>
<node id="Pandemic Period">
  <data key="d0">Pandemic Period</data>
  <data key="d1">event</data>
  <data key="d2">The Pandemic Period refers to the timeframe during which the initial observations on ideological convergence between neo-Nazis and jihadists were made, leading to later documented patterns by 2025.</data>
  <data key="d3">chunk-4117a24ac776e64ee5b10c9c825a2778</data>
