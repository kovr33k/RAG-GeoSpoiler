  <data key="d6"></data>
</node>
<node id="Jacques Santer">
  <data key="d0">Jacques Santer</data>
  <data key="d1">person</data>
  <data key="d2">Jacques Santer was the President of the European Commission who resigned in 1999 following a threat of a motion of censure.</data>
  <data key="d3">chunk-9537adb639f6d92a3c655a2e0dc6a434</data>
