  <data key="d6"></data>
</node>
<node id="The Turner Diaries">
  <data key="d0">The Turner Diaries</data>
  <data key="d1">document</data>
  <data key="d2">The Turner Diaries is an American racist and neo-Nazi literary text that has inspired radical far-right and white jihadist movements.</data>
  <data key="d3">chunk-e9a14fc1e13b7bdf9ed3cf57cf0801e3</data>
