  <data key="d5">1777418926</data>
  <data key="d6"></data>
</node>
<node id="European Parliament">
  <data key="d0">European Parliament</data>
  <data key="d1">organization</data>
  <data key="d2">The European Parliament is the legislative body of the European Union where both far-right and far-left factions initiated votes of no confidence against Ursula von der Leyen in 2025.&lt;SEP&gt;The European Parliament is the legislative body of the European Union where motions of censure are voted upon and where political factions operate.</data>
  <data key="d3">chunk-ffb76e13354613b80f653af13be1e243&lt;SEP&gt;chunk-9537adb639f6d92a3c655a2e0dc6a434</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\20.txt&lt;SEP&gt;D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\21.txt</data>
