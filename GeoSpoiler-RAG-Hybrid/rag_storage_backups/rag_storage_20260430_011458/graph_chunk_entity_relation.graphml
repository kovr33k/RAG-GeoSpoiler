  <data key="d3">chunk-9bd051cb787992a9c82372f39a42ff14</data>
  <data key="d2">The survey reflects German public opinion on the proposed deployment of Bundeswehr soldiers in Ukraine.</data>
  <data key="d1">UNKNOWN</data>
