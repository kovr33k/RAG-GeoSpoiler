  <data key="d0">ISIS</data>
  <data key="d1">organization</data>
  <data key="d2">ISIS is a jihadist organization supported by Atomwaffen Division and referenced within far-right extremist circles as an ideological ally in the context of shared enemies.</data>
  <data key="d3">chunk-4117a24ac776e64ee5b10c9c825a2778</data>
