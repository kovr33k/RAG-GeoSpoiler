</node>
<node id="Телеграм">
  <data key="d0">Телеграм</data>
  <data key="d1">platform</data>
  <data key="d2">Телеграм is the platform where the post containing video and information about the protests was published.&lt;SEP&gt;Телеграм is the platform hosting the post from channel 3299898370, which disseminated Александр Дугин's statement.</data>
  <data key="d3">chunk-9d076bc578a76f0d37205d88cb111e3a&lt;SEP&gt;chunk-d87de5ac222f3f5483a17dcd9be1a802</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Куба\5.txt&lt;SEP&gt;D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\10.txt</data>
  <data key="d5">1777418083</data>
  <data key="d6"></data>
</node>
<node id="Электричество">
  <data key="d0">Электричество</data>
  <data key="d3">chunk-9d076bc578a76f0d37205d88cb111e3a</data>
  <data key="d2">The protests coincide with a two-week-long total blackout of electricity in Куба.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Куба\5.txt</data>
  <data key="d5">1777417868</data>
