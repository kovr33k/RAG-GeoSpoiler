  <data key="d7">Дональд Трамп</data>
</node>
<node id="Росія">
  <data key="d0">Росія</data>
  <data key="d1">country</data>
  <data key="d2">Росія is the source country of the crude oil being shipped to Куба, which the U.S. claims will not benefit financially.</data>
  <data key="d3">chunk-33fbdbc87dc3d63c894c4967c64e416d</data>
