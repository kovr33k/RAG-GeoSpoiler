  <data key="d0">Johann von Leers</data>
  <data key="d1">person</data>
  <data key="d2">Johann von Leers was a Nazi storm unit leader who converted to Islam, adopted the name Omar Amin, fled to Argentina, and worked for Gamal Abdel Nasser; he was a radical antisemitic propagandist under Hitler.</data>
  <data key="d3">chunk-4698e80f89aaeb2bfe1d0d03eef662a4</data>
