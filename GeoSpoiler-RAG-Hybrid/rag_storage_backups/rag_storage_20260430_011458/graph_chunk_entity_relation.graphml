  <data key="d6"></data>
</node>
<node id="Green Deal">
  <data key="d0">Green Deal</data>
  <data key="d1">policy</data>
  <data key="d2">The Green Deal is Ursula von der Leyen’s flagship policy aimed at making the EU climate-neutral, criticized by far-right groups for harming industry and by far-left groups for being insufficient and corporate-friendly.</data>
  <data key="d3">chunk-ffb76e13354613b80f653af13be1e243</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Ультра левые и ультра правые\20.txt</data>
