  <data key="d5">1777418926</data>
  <data key="d6"></data>
</node>
<node id="The Left">
  <data key="d0">The Left</data>
  <data key="d1">organization</data>
  <data key="d2">The Left is a far-left political faction in the European Parliament that criticizes von der Leyen for supporting corporate interests, militarization, and insufficient climate action.&lt;SEP&gt;The Left is an ultraleft political group in the European Parliament that initiated the October 2025 motion of censure.</data>
  <data key="d3">chunk-ffb76e13354613b80f653af13be1e243&lt;SEP&gt;chunk-9537adb639f6d92a3c655a2e0dc6a434</data>
