<node id="Опрос">
  <data key="d0">Опрос</data>
  <data key="d1">document</data>
  <data key="d2">Опрос is a survey indicating public opinion in Germany regarding the deployment of Bundeswehr soldiers in Ukraine, with 44% in favor and 42% opposed.</data>
  <data key="d3">chunk-9bd051cb787992a9c82372f39a42ff14</data>
