  <data key="d1">person</data>
  <data key="d2">Albert Friedrich Huber was a Swiss banker who converted to Islam, financed Islamist organizations, and whose bank, Al-Taqwa, was accused of funding Osama bin Laden and al-Qaeda.</data>
  <data key="d3">chunk-4698e80f89aaeb2bfe1d0d03eef662a4</data>
