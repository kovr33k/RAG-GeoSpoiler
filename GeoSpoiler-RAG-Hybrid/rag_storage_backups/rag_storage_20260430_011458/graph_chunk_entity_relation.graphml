<node id="Tunisia">
  <data key="d0">Tunisia</data>
  <data key="d1">country</data>
  <data key="d2">Tunisia is an authoritarian regime with which the European Union has made financial agreements to intercept migrants, criticized by far-left groups as a human rights violation.</data>
  <data key="d3">chunk-ffb76e13354613b80f653af13be1e243</data>
