  <data key="d6"></data>
</node>
<node id="Israel">
  <data key="d0">Israel</data>
  <data key="d1">country</data>
  <data key="d2">Israel is a country whose actions in the Gaza conflict are fully supported by Ursula von der Leyen, drawing strong condemnation from far-left factions.</data>
  <data key="d3">chunk-ffb76e13354613b80f653af13be1e243</data>
