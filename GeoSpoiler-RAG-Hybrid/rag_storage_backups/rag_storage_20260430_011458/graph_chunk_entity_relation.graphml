  <data key="d0">Європейські країни</data>
  <data key="d1">country</data>
  <data key="d2">Європейські країни are rebuilding their defense industries to support Ukraine.</data>
  <data key="d3">chunk-47985507480c716e0000b869ef2c9aa6</data>
