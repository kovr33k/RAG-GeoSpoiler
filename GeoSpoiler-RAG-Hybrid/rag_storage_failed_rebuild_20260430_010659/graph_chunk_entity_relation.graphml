  <data key="d6"></data>
</node>
<node id="President">
  <data key="d0">President</data>
  <data key="d1">person</data>
  <data key="d2">President is a person who announced the beginning of negotiations with the United States, which served as an additional catalyst for protests.</data>
  <data key="d3">chunk-a2c1fe6eec4b0d533b5269363a9c02da</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Куба\5.txt</data>
