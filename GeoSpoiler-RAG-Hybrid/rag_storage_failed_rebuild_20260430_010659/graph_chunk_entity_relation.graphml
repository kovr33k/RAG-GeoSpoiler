</node>
<node id="U.S. Department of the Treasury">
  <data key="d0">U.S. Department of the Treasury</data>
  <data key="d1">organization</data>
  <data key="d2">U.S. Department of the Treasury is an organization that added Cuba to a list of countries banned from purchasing Russian oil.</data>
  <data key="d3">chunk-26a0c741b3e720a0878cd12efde32ab3</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Куба\6.txt</data>
