<node id="Raúl Guillermo Rodríguez Castro">
  <data key="d0">Raúl Guillermo Rodríguez Castro</data>
  <data key="d1">person</data>
  <data key="d2">Raúl Guillermo Rodríguez Castro is the grandson of Cuban leader Raúl Castro and met with U.S. State Department officials during secret negotiations in Havana.</data>
  <data key="d3">chunk-7e0fc3662465aeaa22012fc5b57b9ab2</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Куба\8.txt</data>
  <data key="d5">1777504068</data>
  <data key="d6"></data>
</node>
<node id="State Department">
  <data key="d0">State Department</data>
  <data key="d1">organization</data>
  <data key="d2">The State Department of the United States led a delegation to Havana for secret talks with Cuban authorities, demanding political prisoner releases, compensation for confiscated assets, and expressing concern over foreign military and intelligence activities near U.S. territory.</data>
  <data key="d3">chunk-7e0fc3662465aeaa22012fc5b57b9ab2</data>
  <data key="d4">D:\ObsidianWiki\GeoSpoiler-RAG\output\normalized\Куба\8.txt</data>
