  <data key="d0">U.S. Coast Guard</data>
  <data key="d1">military_unit</data>
  <data key="d2">U.S. Coast Guard is a military unit that authorized a Russian oil tanker to reach Cuba.</data>
  <data key="d3">chunk-26a0c741b3e720a0878cd12efde32ab3</data>
