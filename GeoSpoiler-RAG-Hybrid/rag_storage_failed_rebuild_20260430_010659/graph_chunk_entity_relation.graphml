  <data key="d0">Ivan Dyakonov</data>
  <data key="d1">person</data>
  <data key="d2">Ivan Dyakonov is the author of the article reporting on Donald Trump's executive order regarding tariffs on oil shipments to Cuba.</data>
  <data key="d3">chunk-a87bd5684f407f2900f544cd1ebd84b2</data>
